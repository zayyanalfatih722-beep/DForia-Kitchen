{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "Represents an item on the restaurant menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "bestseller": { "type": "boolean" },
        "available": { "type": "boolean" },
        "dailyQuota": { "type": "number" },
        "stock": { "type": "number" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "category"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Represents a home page promotional banner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "image": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "image", "order"]
    },
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Represents global settings of the store",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "isOpen": { "type": "boolean" },
        "openingHour": { "type": "string" },
        "closingHour": { "type": "string" },
        "bankName": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "bankAccountHolder": { "type": "string" }
      },
      "required": ["storeName", "address", "phone", "whatsapp", "isOpen"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Represents a promotional coupon code",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string" },
        "discountValue": { "type": "number" },
        "minTransaction": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "code", "discountType", "discountValue", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer food order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerTable": { "type": "string" },
        "notes": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "customerName", "customerPhone", "items", "totalAmount", "status", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Represents a customer testimonial, feedback, or suggestion",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["customerName", "message", "createdAt"]
    }
  },
  "firestore": {
    "/menu/{menuId}": {
      "schema": "MenuItem",
      "description": "Collection of menu items available at the restaurant"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Promotional banners displayed on the homepage slider"
    },
    "/settings/store_settings": {
      "schema": "StoreSettings",
      "description": "Store settings configuration document"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount coupons definition collection"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders history collection"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Customer testimonials, feedback, and suggestions collection"
    }
  }
}
