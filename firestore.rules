rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /menu/{document} {
      allow read, write: if true;
    }
    match /banners/{document} {
      allow read, write: if true;
    }
    match /settings/{document} {
      allow read, write: if true;
    }
    match /coupons/{document} {
      allow read, write: if true;
    }
    match /orders/{document} {
      allow read, write: if true;
    }
    match /testimonials/{document} {
      allow read, write: if true;
    }
  }
}
